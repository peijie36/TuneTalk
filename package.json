{
  "name": "tunetalk",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.21.0",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @tunetalk/web dev",
    "dev:edge": "pnpm --filter @tunetalk/edge dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\""
  },
  "devDependencies": {
    "@eslint/js": "^9.11.0",
    "@next/eslint-plugin-next": "^16.0.2",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.33.2",
    "globals": "^16.5.0",
    "prettier": "^3.2.5",
    "turbo": "^2.0.0",
    "typescript": "^5.4.5",
    "typescript-eslint": "^8.46.4"
  }
}
